# Copy to /etc/nginx/sites-available/nephew.yousirjuan.ai
# See docs/operator/nephew-yousirjuan-ai-deploy.md

server {
    listen 80;
    server_name nephew.yousirjuan.ai;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name nephew.yousirjuan.ai;

    ssl_certificate     /etc/letsencrypt/live/nephew.yousirjuan.ai/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/nephew.yousirjuan.ai/privkey.pem;

    root /opt/nephew/apps/control-tower/dist;
    index index.html;

    # Plan 0068 — the `/api/v1/nephew/*` rewrite that PR #56 added has been
    # removed. The Control Tower frontend (apps/control-tower/src/lib/api.ts)
    # now calls `/api/v1/<x>` directly. The broad `location ~ ^/api/v1/...` block
    # below proxies straight to tower-api on :8088. No rewrite layer.

    # Nephew tower-api (Plan 0061) owns these paths (auth/login/me, tower-status, marketplace, rules, etc.).
    # Must come before broad /api/ catch-all. See NEPHEW_OWNED_PATHS in apps/control-tower/vite.config.ts.
    # Bishop special auth subs have their own block (higher specificity).
    location ~ ^/api/v1/auth/(sso|exchange|\.well-known) {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Cookie $http_cookie;
    }
    location ~ ^/api/v1/(auth|control-tower-apps|admin|healthz|operator|tower-status|brains|marketplace|rules|telemetry|handbook|preflight|route|loop) {
        proxy_pass http://127.0.0.1:8088;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Cookie $http_cookie;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Cookie $http_cookie;
    }

    # Bishop OIDC routes live under /api/v1/auth/oauth/* — proxy legacy /oauth/* from bad redirects
    location /oauth/ {
        proxy_pass http://127.0.0.1:8000/api/v1/auth/oauth/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Cookie $http_cookie;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
