# clinic.yousirjuan.ai — generated by LEDGER-0013 wire-marvelous-app.sh
# Proxies to /opt/clinic/'s server.py on 127.0.0.1:5436
# (Previously misconfigured to point at GitLab's :8929 — fixed 2026-05-21.)

server {
    listen 80;
    listen [::]:80;
    server_name clinic.yousirjuan.ai;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name clinic.yousirjuan.ai;

    ssl_certificate     /etc/letsencrypt/live/clinic.yousirjuan.ai/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/clinic.yousirjuan.ai/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;

    access_log /var/log/nginx/clinic-access.log;
    error_log  /var/log/nginx/clinic-error.log;

    location / {
        proxy_pass http://127.0.0.1:5436;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_read_timeout 90;
    }
}
