# LEDGER-0032 — append to ~/.ssh/config on the operator Mac (LOCAL ONLY).
# HostName values should match operator-hosts.env (hostnames, not IPs, where possible).

Host clinic-vps-claude
    HostName your.vps.hostname.example
    User claude
    Port 2222
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host dgx-claude
    HostName your-dgx-hostname
    User claude
    AddressFamily inet6
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host mt6000-claude
    HostName 192.168.8.1
    User claude
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host ax1800-claude
    HostName 192.168.9.1
    User claude
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host nas-claude
    HostName nasa.local
    User claude
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host onemac-claude
    HostName onemac.local
    User claude
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host bigmac-claude
    HostName bigmac.local
    User claude
    AddressFamily inet
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host twomac-claude
    HostName twomac.local
    User claude
    AddressFamily inet
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host mac-claude
    HostName 127.0.0.1
    User claude
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes
