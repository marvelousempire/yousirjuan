# operator-hosts.env — COPY to operator-hosts.env (gitignored) on your Mac.
# Prefer hostnames (Bonjour .local, VPS FQDN, /etc/hosts aliases) — not raw LAN IPs.
# If a .local name resolves to multiple IPs, pin one line in Mac /etc/hosts or Flint DHCP.

# --- Public VPS (clinic) ---
VPS_SSH_USER=your-vps-user
VPS_SSH_HOST=your.vps.hostname.example
VPS_SSH_PORT=2222
VPS_SSH="${VPS_SSH_USER}@${VPS_SSH_HOST}"

# --- DGX Spark (inner LAN) ---
DGX_SSH_USER=your-dgx-user
# Stable alias in Mac /etc/hosts (often IPv6) when LAN IPv4 is flaky:
DGX_SSH_HOST=your-dgx-hostname
DGX_SSH="-6 -i ${HOME}/.ssh/id_ed25519 ${DGX_SSH_USER}@${DGX_SSH_HOST}"

# --- GL.iNet Flint 2 (inner gateway) — UI login often admin@ ---
INNER_GW=192.168.8.1
FLINT_ROOT_USER=root
FLINT_UI_USER=admin
MT6000_SSH=claude@${INNER_GW}

# --- GL.iNet Slate (AX1800) on Flint WAN subnet — UI/SSH login root@ ---
UPSTREAM_GW=192.168.9.1
SLATE_HOST=${UPSTREAM_GW}
SLATE_SSH_USER=root
AX1800_SSH=${SLATE_SSH_USER}@${SLATE_HOST}

# --- ISP edge gateway (NOT GL.iNet — no claude SSH target) ---
ISP_GW=192.168.0.1

# --- UGreen NAS (inner LAN) ---
NAS_HOST=nasa.local
# UGOS SSH username = your UGOS *web login* name (often NOT literally "admin")
NAS_SSH_USER=your-ugos-web-username
NAS_SSH=${NAS_SSH_USER}@${NAS_HOST}
NAS_SSH_PORT=22
NAS_UGOS_PORT=9999

# --- Fleet Macs (inner LAN — Bonjour ComputerName.local) ---
MAC_ONEMAC_HOST=onemac.local
MAC_ONEMAC_NAME=ONEMAC
MAC_ONEMAC_BOOTSTRAP=your-admin@${MAC_ONEMAC_HOST}

MAC_BIGMAC_HOST=bigmac.local
MAC_BIGMAC_NAME=BigMac
MAC_BIGMAC_BOOTSTRAP=your-admin@${MAC_BIGMAC_HOST}

MAC_TWOMAC_HOST=twomac.local
MAC_TWOMAC_NAME=TWOMAC
MAC_TWOMAC_BOOTSTRAP=your-admin@${MAC_TWOMAC_HOST}

# --- Operator Mac pubkey (one key for the whole fleet) ---
PUBKEY_FILE="${HOME}/.ssh/id_ed25519.pub"

# NOTE ON SECRETS (important for AI protection):
# Do not keep live values in this file when using the unified flow.
# Recommended: put everything (CLAUDE_PASSWORD, all the SSH_* and MAC_* vars, etc.)
# into a protected file at ~/.config/tower/tower.env (chmod 600).
# The fleet-claude dispatcher and all playbooks will source it automatically.
# AI agents are explicitly forbidden from reading the real tower.env.

# --- Default password for claude AI/automation users (Linux targets like DGX, VPS) ---
# When you want a consistent password on the `claude` accounts (for su, console, etc.),
# set it on the target with:  echo 'claude:THEPASSWORD' | sudo chpasswd
# This value lives ONLY in your local gitignored copy of operator-hosts.env.
# The example below is a placeholder — replace with a real strong password in the real file.
# CLAUDE_PASSWORD=your-strong-default-claude-password-here-change-me

# --- Additional Members (human family / operator accounts) + ACL ---
# Use playbooks/add-member.sh or the create scripts directly.
#
# Simple batch (future-proofed):
# MEMBERS="avery bobby nivram yousirjuan"
#
# Per-member (recommended for now):
# AVERY_PUBKEY_FILE=~/.ssh/avery_ed25519.pub
# AVERY_PASSWORD=...   # optional, falls back to CLAUDE_PASSWORD
# AVERY_BOOTSTRAP=...  # for remote mac provisioning etc.
#
# Then run:
#   bash playbooks/add-member.sh avery dgx vps
#   or loop over $MEMBERS in your own one-liner.
