# /etc/iptables/rules.v4 (used by iptables-persistent on Ubuntu)
# LEDGER-0027 — restrict TCP/8642 (hermes API) to LAN + WG + loopback only.
# Re-load with: sudo netfilter-persistent reload
*filter
:INPUT ACCEPT [0:0]
:FORWARD ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
-A INPUT -p tcp --dport 8642 -s 127.0.0.0/8 -j ACCEPT
-A INPUT -p tcp --dport 8642 -s 192.168.8.0/24 -j ACCEPT
-A INPUT -p tcp --dport 8642 -s 10.0.0.0/24 -j ACCEPT
-A INPUT -p tcp --dport 8642 -j DROP
COMMIT
