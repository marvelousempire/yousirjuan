# Sandbox for __TOOL__ — generated by LEDGER-0010 Makefile.
#
# Dedicated network. Scoped workspace mount. Memory capped. Non-root user.

services:
  sandbox:
    build:
      context: .
      dockerfile: Dockerfile
    image: sandbox-__TOOL__:latest
    container_name: sandbox-__TOOL__
    hostname: sandbox-__TOOL__

    # Only this scoped path is visible inside the container.
    # Host: ~/sandbox-workspaces/__TOOL__/
    # Container: /workspace
    volumes:
      - ${HOME}/sandbox-workspaces/__TOOL__:/workspace:rw

    working_dir: /workspace

    # Dedicated network — no traffic to other sandboxes by default.
    networks:
      - sandbox-net-__TOOL__

    # Memory cap. Override per-tool if needed (e.g. n8n=1g, ComfyUI=8g).
    mem_limit: 2g
    memswap_limit: 2g
    cpus: 2.0

    # Stay interactive when invoked via `make run`.
    stdin_open: true
    tty: true

    # Default entrypoint is bash; tools install their own ENTRYPOINT in the
    # Dockerfile if they want a wrapper.
    entrypoint: ["/bin/bash"]

networks:
  sandbox-net-__TOOL__:
    name: sandbox-net-__TOOL__
    driver: bridge
    # internal: true  # uncomment to forbid outbound network from this sandbox
