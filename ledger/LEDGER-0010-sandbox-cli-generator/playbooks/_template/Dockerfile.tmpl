# Sandbox image for __TOOL__ — generated by LEDGER-0010.
#
# Base: debian:bookworm-slim (small + curl/git/jq/python3 pre-installed below).
# Non-root user `sandbox` is the default identity. /workspace is the only
# host-mounted path. No SSH keys, no host dotfiles, no GPG, no AWS creds.

FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

# Common minimum tooling. Tool-specific installs go below the line.
RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates curl wget git jq python3 python3-pip \
      build-essential \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# ─── tool-specific install ───────────────────────────────────────────────────
# Replace this block with what __TOOL__ needs. Examples:
#   RUN curl -sSL https://example.com/install.sh | bash
#   RUN pip install --no-cache-dir __TOOL__
#   RUN npm install -g __TOOL__

# (no-op by default — edit me)
RUN echo "[sandbox-__TOOL__] no tool installed yet — edit Dockerfile" >&2

# ─── non-root user ───────────────────────────────────────────────────────────
RUN useradd -m -u 1000 -s /bin/bash sandbox && \
    mkdir -p /workspace && chown sandbox:sandbox /workspace

USER sandbox
WORKDIR /workspace

# Friendly shell prompt so the operator knows they're inside the sandbox.
ENV PS1='[sandbox:__TOOL__] \w \$ '

CMD ["/bin/bash"]
