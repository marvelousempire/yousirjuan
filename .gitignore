apps/yousirjuan-ios/*.xcodeproj/
apps/yousirjuan-ios/DerivedData/
apps/yousirjuan-ios/build/

# Playwright results
apps/yousirjuan-web/playwright-report/
apps/yousirjuan-web/test-results/
