# .env.example — copy to .env and fill in before deployment

# ─── API Runtime ──────────────────────────────────────────────────────────────
PORT=4000
SESSION_SECRET=change-me-to-a-long-random-string-before-deploying
CORS_ORIGINS=http://localhost:3000

# ─── Ollama / Local LLM ───────────────────────────────────────────────────────
# Mac mini M4 Pro 48 GB  → llama3.2:3b or llama3.1:8b
# MacBook Pro M5 Max 128GB → llama3.3:70b (MLX)
# DGX Spark (CUDA)        → llama3.3:70b or larger
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_MODELS=/home/youruser/.ollama/models

# ─── Kokoro TTS ───────────────────────────────────────────────────────────────
KOKORO_URL=http://localhost:8880

# ─── Database (align with docker-compose.runtime.yml) ─────────────────────────
POSTGRES_PASSWORD=sovereign
DATABASE_URL=postgresql://sovereign:sovereign@localhost:5432/yousirjuan

# ─── Memory ───────────────────────────────────────────────────────────────────
MEMORY_DIR=.data/memory

# ─── Client → API ─────────────────────────────────────────────────────────────
# iOS app env var — set to Mac mini Tailscale/WireGuard IP for real-device use
YOUSIRJUAN_API_URL=http://localhost:4000

# ─── Services ─────────────────────────────────────────────────────────────────
HOMEKIT_BRIDGE_PORT=4002
WEBUI_PORT=3000
GATEWAY_PORT=18789

# ─── Networking / VPS ─────────────────────────────────────────────────────────
DOMAIN=hello.yousirjuan.ai
EMAIL=hello@yousirjuan.ai

# ─── Optional: Google OAuth for Open WebUI ────────────────────────────────────
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_ALLOWED_DOMAINS=yousirjuan.ai
