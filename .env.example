# .env.example — copy to .env and fill in for your deployment
# Used by vps/apply-vps-config.sh and (future) docker/docker-compose.yml

# Public subdomain you've pointed at this VPS via DNS A record
DOMAIN=hello.yousirjuan.ai

# Contact email for Let's Encrypt cert renewal notices
EMAIL=hello@yousirjuan.ai

# Where Ollama stores model files
OLLAMA_MODELS=/home/youruser/.ollama/models

# Open WebUI port (loopback-bound; reverse-proxied by nginx)
WEBUI_PORT=3000

# OpenClaw gateway port
GATEWAY_PORT=18789

# (optional) Google OAuth — set to enable "Sign in with Google" in Open WebUI
# Create at https://console.cloud.google.com → OAuth 2.0 Client IDs
# Authorized redirect URI: https://${DOMAIN}/oauth/google/callback
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_ALLOWED_DOMAINS=yousirjuan.ai
