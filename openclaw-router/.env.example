# Copy to .env and fill in for your deployment

# Where the OpenClaw container reaches Ollama. On a VPS that runs Ollama
# itself, this is host.docker.internal. On a tailnet deployment with brain
# on another machine, use that machine's tailnet hostname (or 100.x.x.x IP).
OLLAMA_URL=http://host.docker.internal:11434
# OLLAMA_URL=http://m1-mac.yousirjuan.ts.net:11434
# OLLAMA_URL=http://thor.yousirjuan.ts.net:11434

# Channel credentials (only set the ones you actually use)
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# Broker — leave blank if you don't want OpenClaw to be able to take any
# action on the host (router-only mode = receives + replies, no host I/O).
# To enable host actions, fill these in AFTER setting up ../broker/.
BROKER_HOST=
BROKER_USER=yousirjuan-agent
BROKER_SSH_KEY=./.ssh-broker-key
